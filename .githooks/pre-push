#!/bin/sh
# pre-push: never push a broken build. If the commits being pushed touch build-relevant
# files, run `npm run build` (which also runs check:data-integrity) and ABORT the push if it
# fails — so a build error can never reach origin/Vercel (the silent failed-deploy class).
# Docs/tickets-only pushes skip the build (kept fast).
Z="0000000000000000000000000000000000000000"
relevant=0
while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$Z" ] && continue
  if [ "$remote_sha" = "$Z" ]; then
    files=$(git show --name-only --pretty=format: "$local_sha" 2>/dev/null)
  else
    files=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null)
  fi
  echo "$files" | grep -qE '^(src/|public/|package\.json|package-lock\.json|tsconfig|next\.config|postcss\.config|eslint\.config|tailwind)' && relevant=1
done
if [ "$relevant" = "1" ]; then
  echo "pre-push: build-relevant changes → running 'npm run build' (this gates the deploy)…"
  if ! npm run build >/tmp/rankings123-prepush.log 2>&1; then
    echo "✗ pre-push BLOCKED: 'npm run build' FAILED — fix it before pushing (a broken build = failed Vercel deploy)."
    tail -25 /tmp/rankings123-prepush.log
    exit 1
  fi
  echo "✓ pre-push: build green."
fi
exit 0
